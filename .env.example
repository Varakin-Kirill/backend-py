# PostgreSQL container settings.
POSTGRES_DB=abzac
POSTGRES_USER=abzac_user
POSTGRES_PASSWORD=CHANGE_ME

# Backend database URL is assembled in docker-compose.yml from POSTGRES_* values.
# If you run backend without Docker, use:
# DATABASE_URL=postgresql://abzac_user:CHANGE_ME@localhost:5432/abzac

# Comma-separated frontend origins allowed by CORS.
# Replace these domains with your real frontend URL before production use.
FRONTEND_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,https://abzac.example.com

# Folder with EPUB files inside backend container.
BOOKS_DIR=demo-books
